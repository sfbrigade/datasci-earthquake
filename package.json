{
  "name": "safehome",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "backend"
  ],
  "scripts": {
    "# LOCAL DEV": "",
    "fastapi-dev": "cd backend && uv sync --extra dev && uv run fastapi dev ../api/index.py",
    "next-dev": "cd apps/web && npm run dev",
    "dev": "run-p next-dev fastapi-dev",
    "build": "cd apps/web && npm run build",
    "start": "cd apps/web && npm run start",
    "lint": "cd apps/web && npm run lint",
    "test": "cd apps/web && npm run test",
    "test:e2e": "cd apps/web && npm run test:e2e",
    "test:e2e:ui": "cd apps/web && npm run test:e2e:ui",
    "test:e2e:debug": "cd apps/web && npm run test:e2e:debug",
    "test:e2e:report": "cd apps/web && npm run test:e2e:report",
    "rebuild": "cd apps/web && npm run rebuild",
    "clean": "cd apps/web && npm run clean",
    "# HYBRID (LOCAL + DOCKER) DEV": "",
    "dev-front": "run-p docker-back next-dev",
    "dev-back": "run-p fastapi-dev docker-front",
    "docker-front": "docker compose up -d frontend --build",
    "docker-back": "docker compose up -d db db_test backend --build",
    "# DOCKER DEV": "",
    "docker-all": "run-p docker-back docker-front"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",                               "eslint-config-prettier": "^10.1.8",                            
    "eslint-plugin-prettier": "^5.5.5",                       
    "eslint-plugin-storybook": "^10.2.10",    
    "npm-run-all": "^4.1.5"
  }
}
