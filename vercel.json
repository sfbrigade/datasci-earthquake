{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"      
    }
  ],
  "ignoreCommand": "echo $VERCEL_GIT_COMMIT_REF | grep 'ci_skip_vercel_build' ",
  "buildCommand": "echo 'chi chi'; echo $VERCEL_GIT_COMMIT_REF; next build ",
  "functions": {
    "api/**": {
      "maxDuration": 20
    }
  }
}
